[
  {
    "name": "geocode_location",
    "description": "Convert a city or location name into latitude, longitude and timezone",
    "parameters": {
      "type": "object",
      "properties": {
        "location": {
          "type": "string",
          "description": "City or location name"
        }
      },
      "required": ["location"]
    }
  },
  {
    "name": "get_weather",
    "description": "Get current weather from latitude and longitude",
    "parameters": {
      "type": "object",
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      },
      "required": ["latitude", "longitude"]
    }
  },
  {
    "name": "get_time",
    "description": "Get current time using timezone returned from geocode_location",
    "parameters": {
      "type": "object",
      "properties": {
        "timezone": {
          "type": "string",
          "description": "Timezone like Asia/Manila"
        }
      },
      "required": ["timezone"]
    }
  },
  {
    "name": "get_user",
    "description": "Find or lookup company user, employee, or person by name. Questions like who is John Doe.",
    "parameters": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the user"
        }
      },
      "required": ["name"]
    }
  },
  {
    "name": "search_knowledge",
    "description": "Search internal company knowledge base",
    "parameters": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        }
      },
      "required": ["query"]
    }
  }
]
